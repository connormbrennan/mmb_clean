SHELL := /bin/bash

.PHONY: all clean

OUTPUTS = ../output/Model_Characteristics_corrections.xlsx \
	../output/mmb_model_paper_map.md \
	../output/model_audit_manual.csv \
	../output/progress.log

all: $(OUTPUTS)

../input ../output:
	mkdir -p $@

../output/Model_Characteristics_corrections.xlsx: ../input/Model_Characteristics_corrections.xlsx | ../output
	ln -s ../input/Model_Characteristics_corrections.xlsx $@

../output/mmb_model_paper_map.md: ../input/mmb_model_paper_map.md | ../output
	ln -s ../input/mmb_model_paper_map.md $@

../output/model_audit_manual.csv: ../input/model_audit_manual.csv | ../output
	ln -s ../input/model_audit_manual.csv $@

../output/progress.log: ../input/progress.log | ../output
	ln -s ../input/progress.log $@

clean:
	find ../output -mindepth 1 -maxdepth 1 -type l -exec unlink {} \;
